# =========================
# APP
# =========================
NODE_ENV=development
PORT=4000

# =========================
# MONGODB
# =========================
MONGODB_URI=mongodb://localhost:your_local_host
MONGODB_NAME=your_database_name

# =========================
# JWT
# =========================
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1d

# =========================
# REDIS / BULLMQ
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =========================
# M-INVOICE
# =========================
M_INVOICE_TOKEN=your_m_invoice_token_here

# =========================
# FILE STORAGE
# =========================
ROOT_PATH=/path/to/project