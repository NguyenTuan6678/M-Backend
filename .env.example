# =========================
# APP
# =========================
NODE_ENV= production
PORT= 4000
LOG_LEVEL= debug
API_BASE_URL= your_api_base_url_here
FRONTEND_URL= your_frontend_url_here

# =========================
# MONGODB
# =========================
MONGODB_URI= your_database_url
MONGODB_NAME= your_database_name

# =========================
# JWT
# =========================
JWT_ACCESS_SECRET= your_jwt_access_secret_here
JWT_REFRESH_SECRET= your_jwt_refresh_secret_here
JWT_EXPIRATION= your_jwt_expiration_time_here

# =========================
# REDIS / BULLMQ
# =========================
REDIS_HOST= your_redis_host_here
REDIS_PORT= your_redis_port_here
REDIS_PASSWORD= your_redis_password_here

# =========================
# M-INVOICE
# =========================
M_INVOICE_TOKEN= your_m_invoice_token_here

# =========================
# FILE STORAGE
# =========================
ROOT_PATH= /path/to/project

# =========================
# ALERT NOTIFICATION
# =========================
ALERT_DISCORD_ENABLED= false
ALERT_DISCORD_WEBHOOK_URL= your_discord_webhook_url_here

ALERT_TELEGRAM_ENABLED= false
ALERT_TELEGRAM_BOT_TOKEN= your_telegram_bot_token_here
ALERT_TELEGRAM_CHAT_ID= your_telegram_chat_id_here

INVOICE_STUCK_MINUTES= 10
INVOICE_FAILED_THRESHOLD= 5
INVOICE_FAILED_WINDOW_MINUTES= 10

INVOICE_EXISTING_FAILED_ALERT_ENABLED= false

# =========================
# AUDIT LOG
# =========================
AUDIT_LOG_FILE_ENABLED= false
AUDIT_LOG_FILE_DIR= logs/audit